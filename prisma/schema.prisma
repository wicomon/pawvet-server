generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  ruc       String?
  website   String?
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  users            User[]
  owners           Owner[]
  pets             Pet[]
  appointments     Appointment[]
  medicalRecords   MedicalRecord[]
  vaccines         Vaccine[]
  products         Product[]
  invoices         Invoice[]
  invoiceItems     InvoiceItem[]
  notificationLogs NotificationLog[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // Hash del password (bcrypt)
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  organizationId String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  appointments   Appointment[]   @relation("AppointmentVet")
  medicalRecords MedicalRecord[] @relation("MedicalRecordVet")
  vaccines       Vaccine[]       @relation("VaccineVet")
  invoices       Invoice[]       @relation("InvoiceCashier")

  @@index([organizationId])
}

model Role {
  id          String   @id @default(uuid())
  name        String // Ej: "Administrador", "Docente", "Estudiante"
  slug        String // Ej: "admin", "teacher", "student"
  description String?
  canRead     Boolean  @default(true)
  canCreate   Boolean  @default(true)
  canUpdate   Boolean  @default(true)
  canDelete   Boolean  @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  // organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users User[]
  menus  RoleMenu[]
  // rolePermissions RolePermission[]

  @@unique([name]) // Un rol único por nombre dentro de cada organización
  @@unique([slug]) // Un rol único por nombre dentro de cada organización
}

model Menu {
  id          String   @id @default(uuid())
  code        String   @unique // Código único interno: "courses", "grades", "reports"
  name        String // Nombre por defecto: "Cursos", "Calificaciones", "Reportes"
  type        String   @default("link") // Tipo de menú: "link", "dropdown"
  position    String   @default("top") // Posición: "sidebar", "topbar"
  description String?
  path        String   // Ruta en el frontend: "/cursos", "/calificaciones"
  icon        String? // Nombre del ícono (ej: "book-open", "graduation-cap")
  order       Int      @default(0) // Orden por defecto
  parentId    String? // Para menús anidados (submenús)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  parent    Menu?      @relation("MenuHierarchy", fields: [parentId], references: [id])
  subMenu   Menu[]     @relation("MenuHierarchy")
  roleMenus RoleMenu[]

  // @@index([parentId])
}

model RoleMenu {
  id          String   @id @default(uuid())
  roleId      String
  menuId      String
  isActive    Boolean  @default(true) 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@index([roleId])
  @@index([menuId])
}

// ── Enums ────────────────────────────────────────────────

enum Species {
  DOG
  CAT
  BIRD
  RABBIT
  REPTILE
  OTHER
}

enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ProductType {
  PRODUCT // ítem físico con stock (alimento, medicina)
  SERVICE // consulta, baño, cirugía — sin stock
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOIDED
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  SMS
}

enum NotificationType {
  APPOINTMENT_REMINDER
  VACCINE_REMINDER
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ── CRM ──────────────────────────────────────────────────

model Owner {
  id             String   @id @default(uuid())
  organizationId String
  firstName      String
  lastName       String
  docType        String? // "DNI" | "RUC" | "CE"
  docNumber      String?
  phone          String? // E.164 (+51...) — destino de WhatsApp
  email          String?
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?
  updatedBy      String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pets         Pet[]
  invoices     Invoice[]

  @@unique([organizationId, docNumber])
  @@index([organizationId, lastName, firstName])
  @@index([organizationId, phone])
}

model Pet {
  id             String    @id @default(uuid())
  organizationId String
  ownerId        String
  name           String
  species        Species
  breed          String?
  sex            Sex       @default(UNKNOWN)
  birthDate      DateTime? @db.Date
  // REGLA ESTRICTA: siempre kilogramos, precisión al gramo. Sin conversiones.
  weightKg       Decimal?  @db.Decimal(6, 3)
  color          String?
  microchip      String?
  photoUrl       String?
  notes          String?
  isActive       Boolean   @default(true)
  deceasedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?
  updatedBy      String?

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner          Owner             @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  vaccines       Vaccine[]
  notifications  NotificationLog[]

  @@index([organizationId, ownerId])
  @@index([organizationId, name])
}

// ── Clínica ──────────────────────────────────────────────

model Appointment {
  id             String            @id @default(uuid())
  organizationId String
  petId          String
  vetId          String? // User asignado (veterinario)
  scheduledAt    DateTime
  durationMin    Int               @default(30)
  status         AppointmentStatus @default(SCHEDULED)
  reason         String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdBy      String?
  updatedBy      String?

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pet           Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet           User?             @relation("AppointmentVet", fields: [vetId], references: [id], onDelete: SetNull)
  medicalRecord MedicalRecord?
  notifications NotificationLog[]

  @@index([organizationId, scheduledAt]) // agenda del día/semana de la clínica
  @@index([organizationId, vetId, scheduledAt]) // agenda por veterinario
  @@index([organizationId, petId]) // historial de citas de la mascota
  @@index([organizationId, status, scheduledAt]) // pendientes de recordatorio
}

model MedicalRecord {
  id             String   @id @default(uuid())
  organizationId String
  petId          String
  appointmentId  String?  @unique // una cita genera a lo sumo un registro
  vetId          String?
  visitDate      DateTime @default(now())
  // Snapshot del peso EN KG en esta visita → historial de peso
  weightKg       Decimal? @db.Decimal(6, 3)
  temperatureC   Decimal? @db.Decimal(4, 1)
  anamnesis      String? // motivo/relato del dueño
  diagnosis      String?
  treatment      String?
  prescription   String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?
  updatedBy      String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pet          Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  vet          User?        @relation("MedicalRecordVet", fields: [vetId], references: [id], onDelete: SetNull)
  vaccines     Vaccine[]

  @@index([organizationId, petId, visitDate(sort: Desc)])
}

model Vaccine {
  id              String    @id @default(uuid())
  organizationId  String
  petId           String
  medicalRecordId String? // opcional: aplicada dentro de una consulta
  vetId           String?
  name            String // "Antirrábica", "Séxtuple"...
  batchNumber     String?
  appliedAt       DateTime  @db.Date
  nextDueAt       DateTime? @db.Date // motor de recordatorios de la Fase 2
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pet           Pet            @relation(fields: [petId], references: [id], onDelete: Cascade)
  medicalRecord MedicalRecord? @relation(fields: [medicalRecordId], references: [id], onDelete: SetNull)
  vet           User?          @relation("VaccineVet", fields: [vetId], references: [id], onDelete: SetNull)

  @@index([organizationId, petId])
  @@index([organizationId, nextDueAt]) // "vacunas que vencen esta semana" → recordatorios
}

// ── Facturación e Inventario ─────────────────────────────

model Product {
  id             String      @id @default(uuid())
  organizationId String
  sku            String?
  name           String
  description    String?
  type           ProductType @default(PRODUCT)
  price          Decimal     @db.Decimal(12, 2) // precio de venta
  cost           Decimal?    @db.Decimal(12, 2) // costo (margen)
  stock          Decimal     @default(0) @db.Decimal(10, 3) // permite fraccionar (kg de alimento)
  trackStock     Boolean     @default(true) // false para servicios
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  createdBy      String?
  updatedBy      String?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@unique([organizationId, sku])
  @@index([organizationId, name])
  @@index([organizationId, type, isActive])
}

model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  ownerId        String? // venta puede ser a cliente casual (null)
  cashierId      String? // User que registró la venta
  issuedAt       DateTime      @default(now())
  status         InvoiceStatus @default(ISSUED)
  currency       String        @default("PEN")
  subtotal       Decimal       @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2) // IGV
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  notes          String?

  // Fase 2: SUNAT (facturación electrónica). Todos nullable:
  // el MVP emite "notas de venta" internas sin tocar estos campos.
  tipoComprobante String? // "01" factura, "03" boleta
  serie           String? // "F001", "B001"
  correlativo     Int?
  estadoSunat     String? // "PENDIENTE" | "ACEPTADO" | "RECHAZADO" | "ANULADO"
  hashFirma       String? // hash del CDR/XML firmado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        Owner?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  cashier      User?         @relation("InvoiceCashier", fields: [cashierId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]

  // Numeración SUNAT única por tenant. En Postgres los NULL no colisionan,
  // así que las ventas del MVP (sin serie) no se bloquean entre sí.
  @@unique([organizationId, serie, correlativo])
  @@index([organizationId, issuedAt(sort: Desc)]) // reporte de ventas por rango
  @@index([organizationId, ownerId])
  @@index([organizationId, status])
}

model InvoiceItem {
  id             String  @id @default(uuid())
  organizationId String // denormalizado a propósito (RLS/particionado futuro)
  invoiceId      String
  productId      String?
  // Snapshot inmutable: si luego cambian nombre/precio del producto,
  // la factura histórica no se altera.
  description    String
  quantity       Decimal @db.Decimal(10, 3)
  unitPrice      Decimal @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([organizationId, productId]) // "¿cuánto vendí de X?" sin JOIN a cabecera
}

// ── Fase 2: Notificaciones (WhatsApp) ────────────────────

model NotificationLog {
  id             String              @id @default(uuid())
  organizationId String
  petId          String? // recordatorio de vacuna
  appointmentId  String? // recordatorio de cita
  channel        NotificationChannel @default(WHATSAPP)
  type           NotificationType
  recipient      String // teléfono E.164 o email, snapshot al momento de envío
  payload        Json? // template + variables enviadas
  status         NotificationStatus  @default(PENDING)
  providerMsgId  String? // id del mensaje en la API de WhatsApp (webhooks de estado)
  error          String?
  scheduledFor   DateTime?
  sentAt         DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pet          Pet?         @relation(fields: [petId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, scheduledFor]) // worker: "pendientes por enviar"
  @@index([providerMsgId]) // resolver webhooks de estado
  @@index([organizationId, appointmentId])
  @@index([organizationId, petId])
}
